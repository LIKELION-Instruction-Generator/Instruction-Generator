STT_QUIZ_DATABASE_URL=postgresql+psycopg://quizsvc:quizsvc@localhost:5433/quizsvc
STT_QUIZ_SYNC_ACCEPTED_WEEKLY_BASELINE=true
STT_QUIZ_SHOW_PIPELINE_OPS=false
STT_QUIZ_EMBEDDING_BACKEND=openai
STT_QUIZ_EMBEDDING_DIM=64
STT_QUIZ_TOP_K=6
STT_QUIZ_EXCLUDE_PRACTICE=true
STT_QUIZ_DEFAULT_MODEL=google-gla:gemini-2.5-flash
STT_QUIZ_PREPROCESS_MODEL=google-gla:gemini-2.5-flash
STT_QUIZ_WEEKLY_MODEL=google-gla:gemini-2.5-flash
STT_QUIZ_PREPROCESS_BLOCK_CHARS=3000
STT_QUIZ_KEYWORD_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
STT_QUIZ_DAILY_TERM_CANDIDATE_LIMIT=40
STT_QUIZ_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
STT_QUIZ_LLM_BACKEND=pydanticai
STT_QUIZ_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# LangChain strict RAG baseline
STT_QUIZ_RAG_LLM_PROVIDER=google
STT_QUIZ_RAG_LLM_MODEL=gemini-2.5-flash
STT_QUIZ_RAG_COLLECTION=stt_quiz_chunks_v2
STT_QUIZ_RAG_CHUNK_SIZE=800
STT_QUIZ_RAG_CHUNK_OVERLAP=100
STT_QUIZ_RAG_RETRIEVER_TOP_K=6
STT_QUIZ_RAG_GENERATION_TOP_K=3

# LangSmith tracing
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=stt-quiz-service
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=

OPENAI_API_KEY=
GOOGLE_API_KEY=
